# Skopiuj do .env (lokalnie). Na GitHub Actions ustaw jako Secrets / Variables.

# --- Secrets (Repository → Settings → Secrets and variables → Actions) ---
SERPAPI_API_KEY=
OPENAI_API_KEY=
SMTP_USER=
SMTP_PASS=
CV_DRIVE_ID=
# Opcjonalnie: upload zip na Google Drive (workflow weekly-gdrive-publish)
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_FOLDER_ID=

# --- Variables (Actions → Variables); można też nadpisać w .env lokalnie ---
# PIPELINE_DRY_RUN=1 — nie wysyła maili przez SMTP (nadaje się do testów w CI ręcznych)
# REPORT_EMAIL_TO= — odbiorca raportu .xlsx z send_report_email

# --- Ścieżki (opcjonalnie w Actions) ---
# PIPELINE_OUTPUT_DIR=artifacts/reports
