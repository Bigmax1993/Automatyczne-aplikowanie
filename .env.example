# Skopiuj do pliku .env i uzupełnij wartości. NIE commituj .env z prawdziwymi sekretami.
# Na GitHub Actions: poniższe API/SMTP/Drive (CV) ustaw jako Secrets; opcjonalnie Variables jak w workflow.

# SerpApi (Google Jobs / Google Search)
SERPAPI_API_KEY=

# OpenAI — generowanie treści maili (tylko znaki ASCII, np. sk-...; polski placeholder z ó złamie nagłówek HTTP)
OPENAI_API_KEY=

# Gmail (SMTP) — wysyłka
SMTP_USER=
SMTP_PASS=

# Google Drive — ID pliku CV (udostępniony link / plik)
CV_DRIVE_ID=

# Opcjonalnie: poziom logów (DEBUG, INFO, …)
LOG_LEVEL=INFO

# Pipeline: true = generuj maile i raport, bez wysyłki SMTP
PIPELINE_DRY_RUN=false

# Wznów z data/checkpoints/*.parquet po przerwaniu
PIPELINE_RESUME=false

# Po udanym przebiegu usuń checkpointy (true/false)
CLEAR_CHECKPOINT_ON_SUCCESS=true

# --- Tylko GitHub Actions (sekrety / zmienne repozytorium; nie używane przez pipeline_validate) ---
# GDRIVE_SERVICE_ACCOUNT_JSON=  # weekly-gdrive-publish
# GDRIVE_FOLDER_ID=
# REPORT_EMAIL_TO=              # odbiorca raportu .xlsx
# PIPELINE_OUTPUT_DIR=          # np. artifacts/reports
